{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["server.ts", "dictionary/**/*.ts", "game/**/*.ts", "types/**/*.ts"]
}
